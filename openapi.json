            "format": "binary",
            "description": "Nova imagem (opcional)"
          }
        }
      },
      "ProductUpdateRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 150,
            "minLength": 2
          },
          "description": {
            "type": "string",
            "maxLength": 2000,
            "minLength": 0
          },
          "material": {
            "type": "string",
            "maxLength": 100,
            "minLength": 0
          },
          "multicolor": {
            "type": "boolean"
          },
          "dimensions": {
            "type": "string",
            "maxLength": 100,
            "minLength": 0
          },
          "categoryId": {
            "type": "integer",
            "format": "int64"
          },
          "isVisible": {
            "type": "boolean"
          },
          "featured": {
            "type": "boolean"
          },
          "price": {
            "type": "number",
            "minimum": 0.01
          }
        }
      },
      "ProductResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
